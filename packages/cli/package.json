{
  "name": "@upstash/ahi",
  "version": "0.1.3",
  "description": "Framework for running independent agents",
  "type": "module",
  "bin": {
    "ahi": "./dist/cli.js"
  },
  "files": [
    "dist",
    "console",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "bundle:console": "node ./scripts/bundle-console.mjs",
    "dev": "tsup --watch",
    "prepack": "pnpm --dir ../console build && pnpm build && pnpm bundle:console"
  },
  "dependencies": {
    "@upstash/box": "latest",
    "commander": "^13.0.0",
    "dotenv": "^16.4.0",
    "js-yaml": "^4.1.0",
    "chalk": "^5.4.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
